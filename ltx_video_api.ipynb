   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 🎬 LTX-Video API - Ready to Run"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Clone LTX-Video\n",
    "!git clone https://github.com/Lightricks/LTX-Video.git\n",
    "%cd LTX-Video\n",
    "!pip install -q -e ."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Install deps (fix version conflicts)\n",
    "!pip install torch torchvision --upgrade -q 2>/dev/null\n",
    "!pip install diffusers>=0.32.0 transformers>=4.48.0 -q 2>/dev/null\n",
    "!pip install accelerate sentencepiece -q"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Download model\n",
    "!python app.py download\n",
    "# OR set HF_TOKEN env var and run:\n",
    "# !python app.py download --repo-id \"Lightricks/LTX-Video\"\n",
    "# Then run:\n",
    "# !python app.py serve"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Launch server\n",
    "import subprocess\n",
    "proc = subprocess.Popen([\"python\", \"app.py\", \"serve\", \"--port\", \"8080\"], \n",
    "                        stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n",
    "print(\"LTX-Video API starting on port 8080...\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Expose with ngrok\n",
    "!pip install pyngrok -q\n",
    "from pyngrok import ngrok\n",
    "\n",
    "public_url = ngrok.connect(8080)\",
    "print(f\"🚀 LTX-Video API: {public_url}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Test it\n",
    "import requests, time\n",
    "time.sleep(5)\n",
    "res = requests.get(f\"{public_url}/health\").json()\n",
    "print(res)"
   ]
  }
